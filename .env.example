# L2SC environment — copy thành .env và chỉnh lại
# =====================================================

# Database (docker-compose tự set khi dùng docker compose up)
DATABASE_URL=postgresql://postgres:postgres@localhost:9992/l2sc

# Admin API key cố định (để trống = random mỗi lần start, phải ghi lại từ log)
L2SC_ADMIN_API_KEY=
